<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Join DevDashboard - Create Account</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col justify-between">

  <nav class="bg-white shadow-sm border-b border-slate-200 py-4 px-6 flex justify-between items-center">
    <a href="/" class="text-xl font-bold text-indigo-600 tracking-tight">DevDashboard</a>
    <a href="/" class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">&larr; Back to Home</a>
  </nav>

  <main class="flex-grow flex items-center justify-center p-6">
    <div class="bg-white p-8 rounded-2xl shadow-md border border-slate-100 max-w-md w-full">
      
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-slate-900">Create your account</h1>
        <p class="text-slate-500 text-sm mt-1">Get access to platform articles, or register as an admin to write posts.</p>
      </div>

      <!-- Error Handling Window -->
      <% if (error) { %>
        <div class="mb-5 bg-rose-50 border border-rose-200 text-rose-700 px-4 py-3 rounded-xl text-sm flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <!-- Form target matching your POST endpoint -->


      
      <form action="/register" method="POST" class="space-y-4">
        
        <div>
          <label for="username" class="block text-sm font-semibold text-slate-700 mb-1.5">Username</label>
          <input 
            type="text" 
            id="username" 
            name="username" 
            placeholder="Enter a unique username" 
            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-indigo-500 focus:bg-white transition-all"
            required
          >
        </div>

        <div>
          <label for="password" class="block text-sm font-semibold text-slate-700 mb-1.5">Password</label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            placeholder="••••••••" 
            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-indigo-500 focus:bg-white transition-all"
            required
          >
        </div>

        <!-- <div>
          <label for="role" class="block text-sm font-semibold text-slate-700 mb-1.5">Account Role</label>
          <select 
            id="role" 
            name="role" 
            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-indigo-500 focus:bg-white transition-all"
          >
            <option value="user">User (Reader access)</option>
            <option value="admin">Admin (Publish privileges)</option>
          </select>
        </div> -->
  <input type="hidden" name="role" value="user">
        <button 
          type="submit" 
          class="w-full mt-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 rounded-xl text-sm transition-colors shadow-sm"
        >
          Register Account
        </button>

      </form>

      <div class="mt-6 text-center border-t border-slate-100 pt-4 text-sm text-slate-500">
        Already have an account? 
        <a href="/login" class="text-indigo-600 font-semibold hover:underline">Sign in here</a>
      </div>
    </div>
  </main>

  <footer class="text-center py-4 text-xs text-slate-400 border-t border-slate-100 bg-white">
    &copy; DevDashboard. All rights reserved.
  </footer>

</body>
</html>