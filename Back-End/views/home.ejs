<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DevDashboard - Community Blogs</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col justify-between">

  <nav class="bg-white shadow-sm border-b border-slate-200 py-4 px-6 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="/" class="text-xl font-bold text-indigo-600 tracking-tight">DevDashboard</a>
      
      <div id="auth-nav" class="flex items-center gap-4">
        <p class="text-xs text-slate-400">Loading session...</p>
      </div>
    </div>
  </nav>

  <header class="bg-white border-b border-slate-100 py-12 px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight leading-tight">
        Welcome to the Developer Hub
      </h1>
      <p class="text-slate-500 text-base mt-2 max-w-xl mx-auto">
        Explore modern development workflows, architectural notes, and tech articles posted by our engineering admins.
      </p>
    </div>
  </header>

  <main class="flex-grow max-w-7xl w-full mx-auto p-6 md:p-8">
    <div id="blogs-container">
      <p class="text-center text-slate-500 text-sm animate-pulse">Loading feed entries...</p>
    </div>
  </main>

  <div id="edit-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-xs flex items-center justify-center p-4 z-50 hidden">
    <div class="bg-white rounded-2xl border border-slate-200 shadow-xl max-w-md w-full p-6 relative">
      <h3 class="text-lg font-bold text-slate-900 mb-1">Modify Technical Post</h3>
      <p class="text-xs text-slate-500 mb-4">Overwrite the title, abstract copy, or cover resource image below.</p>
      
      <form id="edit-form" onsubmit="submitBlogEdit(event)" class="space-y-4">
        <input type="hidden" id="edit-blog-id">
        
        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-1">Article Title</label>
          <input type="text" id="edit-title" required class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-hidden focus:border-indigo-500 focus:bg-white transition-all">
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-1">Image URL</label>
          <input type="url" id="edit-image-url" required class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-hidden focus:border-indigo-500 focus:bg-white transition-all">
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-1">Content Summary</label>
          <textarea id="edit-description" rows="4" required class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-hidden focus:border-indigo-500 focus:bg-white transition-all resize-none"></textarea>
        </div>

        <div class="flex justify-end gap-2 pt-2">
          <button type="button" onclick="closeEditModal()" class="px-4 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-all cursor-pointer">
            Cancel
          </button>
          <button type="submit" class="px-4 py-2 text-xs font-semibold text-white bg-indigo-600 hover:bg-indigo-700 rounded-xl shadow-xs transition-all cursor-pointer">
            Save Changes
          </button>
        </div>
      </form>
    </div>
  </div>

  <footer class="text-center py-5 text-xs text-slate-400 border-t border-slate-200 bg-white">
    &copy; DevDashboard. Powered by Node.js, Express, JWT, and MongoDB.
  </footer>

  <script>
    document.addEventListener("DOMContentLoaded", async () => {
      const authNav = document.getElementById("auth-nav");
      const blogsContainer = document.getElementById("blogs-container");

      // 1. Read token string and user schema out of LocalStorage
      const token = localStorage.getItem("token");
      const savedUser = localStorage.getItem("user");
      let user = null;

      if (savedUser) {
        try {
          user = JSON.parse(savedUser);
        } catch(e) {
          console.error("Failed to parse user profile structural layout data", e);
        }
      }

      // ==========================================
      // PHASE A: COMPUTE NAVBAR RENDER VIA LOGGED IN PROFILE
      // ==========================================
      if (token && user) {
        let adminButton = "";
        if (user.role === "admin") {
          adminButton = `
            <a href="/admin-panel" class="bg-slate-900 hover:bg-slate-800 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-all shadow-sm">
              ⚙️ Admin Panel
            </a>
            <a href="/create-blog" class="bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-all shadow-sm">
              + New Post
            </a>`;
        }
        
        authNav.innerHTML = `
          ${adminButton}
          <span class="text-xs text-slate-500 bg-slate-100 px-3 py-1.5 rounded-lg border border-slate-200">
            Logged in as: <strong class="text-slate-700">${user.username} (${user.role})</strong>
          </span>
          <button id="logout-btn" class="text-xs font-medium text-rose-600 hover:text-rose-700 transition-colors cursor-pointer">
            Logout
          </button>
        `;

        // Interactive Client Logout handler
        document.getElementById("logout-btn").addEventListener("click", () => {
          localStorage.removeItem("token");
          localStorage.removeItem("user");
          window.location.reload(); 
        });

      } else {
        // Fallback layout state for guests
        authNav.innerHTML = `
          <a href="/login" class="text-xs font-semibold text-slate-600 hover:text-slate-900 transition-colors">Login</a>
          <a href="/register" class="bg-slate-900 hover:bg-slate-800 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-all">Register</a>
        `;
      }

      // ==========================================
      // PHASE B: POPULATE COLLECTION LOGISTICS VIA BACKEND ENDPOINT
      // ==========================================
      try {
        const response = await axios.get("/api/blogs");
        const blogs = response.data.blogs;

        if (blogs && blogs.length > 0) {
          blogsContainer.innerHTML = `<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="grid-layout"></div>`;
          const gridLayout = document.getElementById("grid-layout");

          blogs.forEach(blog => {
            const dateStr = new Date(blog.createdAt || Date.now()).toLocaleDateString('en-US', { 
              month: 'short', 
              day: 'numeric', 
              year: 'numeric' 
            });
            
            // Generate both Edit and Delete action buttons if the user is an admin
            let adminActions = "";
            if (user && user.role === "admin") {
              // Safely escape strings so special characters don't break our HTML attributes
              const safeTitle = encodeURIComponent(blog.title);
              const safeDesc = encodeURIComponent(blog.description);
              const safeImg = encodeURIComponent(blog.imageUrl);

              adminActions = `
                <div class="flex items-center gap-2">
                  <button onclick="openEditModal('${blog._id}', '${safeTitle}', '${safeDesc}', '${safeImg}')" class="text-xs bg-amber-50 hover:bg-amber-100 border border-amber-200 text-amber-700 px-2.5 py-1 rounded-lg cursor-pointer transition-all">
                    Edit
                  </button>
                  <button onclick="deleteArticle('${blog._id}')" class="text-xs bg-rose-50 hover:bg-rose-100 border border-rose-200 text-rose-600 px-2.5 py-1 rounded-lg cursor-pointer transition-all">
                    Wipe Post
                  </button>
                </div>
              `;
            }
            
            gridLayout.innerHTML += `
              <article id="post-card-${blog._id}" class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden flex flex-col justify-between group hover:shadow-md transition-all">
                <div>
                  <div class="h-48 w-full bg-slate-100 overflow-hidden">
                    <img id="post-img-${blog._id}" src="${blog.imageUrl}" alt="${blog.title}" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-300" onerror="this.src='https://images.unsplash.com/photo-1618477388954-7852f32655ec?q=80&w=600'">
                  </div>
                  <div class="p-5">
                    <div class="text-slate-400 text-[11px] font-medium uppercase tracking-wider mb-2">${dateStr}</div>
                    <h2 id="post-title-${blog._id}" class="text-lg font-bold text-slate-900 line-clamp-2 leading-snug group-hover:text-indigo-600 transition-colors">${blog.title}</h2>
                    <p id="post-desc-${blog._id}" class="text-slate-500 text-sm mt-2 line-clamp-4 leading-relaxed">${blog.description}</p>
                  </div>
                </div>
                <div class="px-5 pb-5 pt-2 border-t border-slate-50 flex justify-between items-center">
                  <span class="text-xs font-semibold text-indigo-600 flex items-center gap-1 group-hover:gap-2 transition-all">
                    Read Article <span>&rarr;</span>
                  </span>
                  ${adminActions}
                </div>
              </article>
            `;
          });
        } else {
          showEmptyState(user);
        }
      } catch (err) {
        console.error("Error running client fetching logic:", err);
        blogsContainer.innerHTML = `<p class="text-center text-rose-500 text-sm font-medium">Failed to load articles from the database server.</p>`;
      }
    });

    // Global action handler function to execute blog post removal via Axios
    window.deleteArticle = async (blogId) => {
      if (!confirm("Are you absolutely sure you want to delete this technical article?")) return;

      const token = localStorage.getItem("token");
      try {
        const response = await axios.delete(`/api/blogs/${blogId}`, {
          headers: { Authorization: `Bearer ${token}` }
        });

        if (response.data.success) {
          const postCard = document.getElementById(`post-card-${blogId}`);
          if (postCard) {
            postCard.remove();
          }
        }
      } catch (err) {
        console.error("Article removal failure:", err);
        alert(err.response?.data?.message || "Failed to remove the post.");
      }
    };

    // Global modal control helpers to load post content elements inside the form fields
    window.openEditModal = (id, title, description, imageUrl) => {
      document.getElementById("edit-blog-id").value = id;
      document.getElementById("edit-title").value = decodeURIComponent(title);
      document.getElementById("edit-description").value = decodeURIComponent(description);
      document.getElementById("edit-image-url").value = decodeURIComponent(imageUrl);
      
      document.getElementById("edit-modal").classList.remove("hidden");
    };

    window.closeEditModal = () => {
      document.getElementById("edit-modal").classList.add("hidden");
      document.getElementById("edit-form").reset();
    };

    // Client action handler to update an existing blog via an HTTP PUT call
    window.submitBlogEdit = async (event) => {
      event.preventDefault();
      
      const token = localStorage.getItem("token");
      const blogId = document.getElementById("edit-blog-id").value;
      
      const payload = {
        title: document.getElementById("edit-title").value,
        description: document.getElementById("edit-description").value,
        imageUrl: document.getElementById("edit-image-url").value
      };

      try {
        const response = await axios.put(`/api/blogs/${blogId}`, payload, {
          headers: { Authorization: `Bearer ${token}` }
        });

        if (response.data.success) {
          const updated = response.data.blog;
          
          // Instantly patch the specific layout cards directly on the dashboard screen
          document.getElementById(`post-title-${blogId}`).innerText = updated.title;
          document.getElementById(`post-desc-${blogId}`).innerText = updated.description;
          document.getElementById(`post-img-${blogId}`).src = updated.imageUrl;
          
          closeEditModal();
        }
      } catch (err) {
        console.error("Failed to commit edits:", err);
        alert(err.response?.data?.message || "Unable to update article contents.");
      }
    };

    function showEmptyState(user) {
      const blogsContainer = document.getElementById("blogs-container");
      let writeButton = "";
      if (user && user.role === "admin") {
        writeButton = `
          <a href="/create-blog" class="inline-block mt-4 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold px-4 py-2.5 rounded-xl transition-all">
            Write First Post
          </a>`;
      }
      blogsContainer.innerHTML = `
        <div class="text-center py-20 max-w-md mx-auto">
          <div class="w-16 h-16 bg-indigo-50 border border-indigo-100 rounded-2xl flex items-center justify-center mx-auto mb-4 text-indigo-500">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900">No post feeds yet</h3>
          <p class="text-slate-500 text-sm mt-1">The publication pipeline is empty. If you're an admin, jump in and create the first technical broadcast!</p>
          ${writeButton}
        </div>`;
    }
  </script>
</body>
</html>