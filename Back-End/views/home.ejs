<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DevDashboard - Community Blogs</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col justify-between">

  <!-- Navbar Navigation -->
  <nav class="bg-white shadow-sm border-b border-slate-200 py-4 px-6 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="/" class="text-xl font-bold text-indigo-600 tracking-tight">DevDashboard</a>
      
      <div class="flex items-center gap-4">
        <% if (user) { %>
          <!-- Admin Context Action Button -->
          <% if (user.role === 'admin') { %>
            <a href="/create-blog" class="bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-all shadow-sm shadow-indigo-100">
              + New Post
            </a>
          <% } %>
          <span class="text-xs text-slate-500 bg-slate-100 px-3 py-1.5 rounded-lg border border-slate-200">
            Logged in as: <strong class="text-slate-700"><%= user.username %> (<%= user.role %>)</strong>
          </span>
          <a href="/logout" class="text-xs font-medium text-rose-600 hover:text-rose-700 transition-colors">
            Logout
          </a>
        <% } else { %>
          <a href="/login" class="text-xs font-semibold text-slate-600 hover:text-slate-900 transition-colors">Login</a>
          <a href="/register" class="bg-slate-900 hover:bg-slate-800 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-all">Register</a>
        <% } %>
      </div>
    </div>
  </nav>

  <!-- Hero Welcome Banner -->
  <header class="bg-white border-b border-slate-100 py-12 px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight leading-tight">
        Welcome to the Developer Hub
      </h1>
      <p class="text-slate-500 text-base mt-2 max-w-xl mx-auto">
        Explore modern development workflows, architectural notes, and tech articles posted by our engineering admins.
      </p>
    </div>
  </header>

  <!-- Main Content Grid -->
  <main class="flex-grow max-w-7xl w-full mx-auto p-6 md:p-8">
    
    <% if (blogs && blogs.length > 0) { %>
      <!-- Grid Container -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% blogs.forEach(blog => { %>
          <article class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden flex flex-col justify-between group hover:shadow-md transition-all">
            <div>
              <!-- Card Image Cover -->
              <div class="h-48 w-full bg-slate-100 relative overflow-hidden">
                <img 
                  src="<%= blog.imageUrl %>" 
                  alt="<%= blog.title %>"
                  class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-300"
                  onerror="this.src='https://images.unsplash.com/photo-1618477388954-7852f32655ec?q=80&w=600'"
                >
              </div>
              
              <!-- Card Meta Content -->
              <div class="p-5">
                <div class="text-slate-400 text-[11px] font-medium uppercase tracking-wider mb-2">
                  <%= new Date(blog.createdAt || Date.now()).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                </div>
                <h2 class="text-lg font-bold text-slate-900 line-clamp-2 leading-snug group-hover:text-indigo-600 transition-colors">
                  <%= blog.title %>
                </h2>
                <p class="text-slate-500 text-sm mt-2 line-clamp-4 leading-relaxed">
                  <%= blog.description %>
                </p>
              </div>
            </div>

            <!-- Footer Action Area -->
            <div class="px-5 pb-5 pt-2 border-t border-slate-50 flex justify-between items-center">
              <span class="text-xs font-semibold text-indigo-600 flex items-center gap-1 group-hover:gap-2 transition-all">
                Read Article <span>&rarr;</span>
              </span>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <!-- Empty Feed Fallback State -->
      <div class="text-center py-20 max-w-md mx-auto">
        <div class="w-16 h-16 bg-indigo-50 border border-indigo-100 rounded-2xl flex items-center justify-center mx-auto mb-4 text-indigo-500">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-slate-900">No post feeds yet</h3>
        <p class="text-slate-500 text-sm mt-1">
          The publication pipeline is empty. If you're an admin, jump in and create the first technical broadcast!
        </p>
        <% if (user && user.role === 'admin') { %>
          <a href="/create-blog" class="inline-block mt-4 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold px-4 py-2.5 rounded-xl transition-all">
            Write First Post
          </a>
        <% } %>
      </div>
    <% } %>

  </main>

  <!-- Sticky Project Footer -->
  <footer class="text-center py-5 text-xs text-slate-400 border-t border-slate-200 bg-white">
    &copy; DevDashboard. Powered by Node.js, Express, and MongoDB.
  </footer>

</body>
</html>