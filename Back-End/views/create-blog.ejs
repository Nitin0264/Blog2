<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create New Blog Post</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col justify-between">

  <nav class="bg-white shadow-sm border-b border-slate-200 py-4 px-6 flex justify-between items-center">
    <a href="/" class="text-xl font-bold text-indigo-600 tracking-tight">DevDashboard</a>
    <a href="/" class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">&larr; Back to Home</a>
  </nav>

  <main class="flex-grow flex items-center justify-center p-6">
    <div class="bg-white p-8 rounded-2xl shadow-md border border-slate-100 max-w-xl w-full">
      
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-slate-900">Create a New Post</h1>
        <p class="text-slate-500 text-sm mt-1">Publish a fresh technical article via secure JWT authorization.</p>
      </div>

      <div id="error-box" class="hidden mb-5 bg-rose-50 border border-rose-200 text-rose-700 px-4 py-3 rounded-xl text-sm flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span id="error-message"></span>
      </div>

      <form id="create-blog-form" class="space-y-5">
        
        <div>
          <label for="title" class="block text-sm font-semibold text-slate-700 mb-1.5">Blog Title</label>
          <input 
            type="text" 
            id="title" 
            placeholder="e.g., Mastering ES Modules in Node.js" 
            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-indigo-500 focus:bg-white transition-all"
            required
          >
        </div>

        <div>
          <label for="imageUrl" class="block text-sm font-semibold text-slate-700 mb-1.5">Cover Image URL</label>
          <input 
            type="url" 
            id="imageUrl" 
            placeholder="https://images.unsplash.com/... or local path" 
            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-indigo-500 focus:bg-white transition-all"
            required
          >
        </div>

        <div>
          <label for="description" class="block text-sm font-semibold text-slate-700 mb-1.5">Content / Description</label>
          <textarea 
            id="description" 
            rows="6" 
            placeholder="Write your blog content or markdown summary here..." 
            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-indigo-500 focus:bg-white transition-all resize-none"
            required
          ></textarea>
        </div>

        <div class="flex items-center gap-3 pt-2">
          <button 
            type="submit" 
            class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 rounded-xl text-sm transition-colors shadow-sm"
          >
            Publish Post
          </button>
          <a 
            href="/" 
            class="px-4 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium rounded-xl text-sm transition-colors text-center"
          >
            Cancel
          </a>
        </div>

      </form>
    </div>
  </main>

  <footer class="text-center py-4 text-xs text-slate-400 border-t border-slate-100 bg-white">
    &copy; DevDashboard. All rights reserved.
  </footer>

  <script>
    // Security check immediately on page layout execution
    const token = localStorage.getItem("token");
    if (!token) {
      alert("Access Denied. Please log in first!");
      window.location.href = "/login";
    }

    document.getElementById("create-blog-form").addEventListener("submit", async (e) => {
      e.preventDefault(); // Stop native page reload

      const title = document.getElementById("title").value;
      const imageUrl = document.getElementById("imageUrl").value;
      const description = document.getElementById("description").value;
      const errorBox = document.getElementById("error-box");
      const errorMessage = document.getElementById("error-message");

      errorBox.classList.add("hidden");

      try {
        // DISPATCH AUTHORIZED BACKGROUND POST TO APIS
        const response = await axios.post("/api/blogs", {
          title: title,
          imageUrl: imageUrl,
          description: description
        }, {
          // KEY UPGRADE: Attach the JWT token inside the authorization headers!
          headers: {
            Authorization: `Bearer ${token}`
          }
        });

        if (response.data.success) {
          alert("Success! Article created using JWT verification.");
          window.location.href = "/"; // Send user back to dynamic dashboard home feed
        }
      } catch (err) {
        errorBox.classList.remove("hidden");
        if (err.response && err.response.data) {
          errorMessage.innerText = err.response.data.message;
        } else {
          errorMessage.innerText = "An error occurred while publishing the post.";
        }
      }
    });
  </script>

</body>
</html>